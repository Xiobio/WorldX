# === WorldX Environment Configuration ===

# --- LLM for Simulation Engine (Volcengine Ark / OpenAI-compatible) ---
LLM_API_KEY=your-ark-api-key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_DEFAULT_MODEL=doubao-seed-2.0-lite
LLM_STRUCTURED_OUTPUT_MODE=auto

# --- Map & Character Generation (OpenRouter for Gemini models) ---
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Orchestrator LLM (Volcengine Ark) ---
ARK_MODEL=doubao-seed-2.0-pro
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_MODEL=ark-code-latest
ARK_STRUCTURED_OUTPUT_MODE=auto

# --- Generation Tuning ---
MAP_IMAGE_SIZE_K=1
# BLOCK_SIZE=4
STEP1_MAX_RETRIES=3
STEP3_1_MAX_RETRIES=3
STEP3_2_MAX_RETRIES=3
STEP4_MAX_RETRIES=3
